{
  "name": "@huh-david/bmp-js",
  "version": "0.3.0",
  "description": "A pure TypeScript BMP encoder and decoder for Node.js",
  "keywords": [
    "bmp",
    "cjs",
    "decoder",
    "encoder",
    "esm",
    "image",
    "typescript"
  ],
  "homepage": "https://github.com/Huh-David/bmp-js#readme",
  "bugs": {
    "url": "https://github.com/Huh-David/bmp-js/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Huh-David/bmp-js.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Huh-David"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --import-plugin --vitest-plugin src test",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.test.json --noEmit",
    "fixtures:generate": "node scripts/generate-bmp-fixtures.mjs",
    "fixtures:validate": "node scripts/validate-fixture-provenance.mjs",
    "pack:check": "npm pack --dry-run > /dev/null",
    "check": "pnpm format:check && pnpm lint && pnpm fixtures:validate && pnpm typecheck && pnpm test && pnpm pack:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepack": "pnpm clean && pnpm build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.6.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.22.0"
}
